<?xml version="1.0" encoding="UTF-8"?>
<!--
  TRAINNORTH:LABS sitemap.

  The current build is a single-page site with in-page anchors. Anchors are
  deliberately NOT listed as separate <url> entries: Google ignores fragment
  URLs in sitemaps and listing them is a common way to look like you have
  coverage you do not have.

  The commented block at the foot lists the routes to add as real pages are
  built. Uncomment each one only once the page returns 200 and is linked from
  site navigation — a sitemap entry for a page with no internal links is a
  crawl-budget leak, not a ranking signal.

  lastmod must be updated on genuine content change only. Refreshing every
  lastmod on every deploy trains Google to ignore the field entirely.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <url>
    <loc>https://trainnorthlabs.com/</loc>
    <lastmod>2026-07-23</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    <xhtml:link rel="alternate" hreflang="en-GB" href="https://trainnorthlabs.com/"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="https://trainnorthlabs.com/"/>
  </url>

